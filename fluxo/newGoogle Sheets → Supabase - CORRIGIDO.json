    {
      "parameters": {
        "jsCode": "/**\n * MAPEAMENTO DE DADOS: Planilha -> Tabela liberation_data\n * FILTRO: Apenas admissões a partir de 01/01/2026\n * LOGS: Ativados para depuração de contagem\n */\n\nfunction excelSerialToDate(serial) {\n  const excelEpoch = new Date(Date.UTC(1899, 11, 30));\n  return new Date(excelEpoch.getTime() + Number(serial) * 86400000);\n}\n\nfunction parseDate(value) {\n  if (!value || value === \"\") return null;\n  if (value instanceof Date && !isNaN(value)) return value;\n  if (typeof value === 'number') return excelSerialToDate(value);\n  const str = String(value).trim();\n  const dmy = str.match(/^(\\d{1,2})[\\/\\-](\\d{1,2})[\\/\\-](\\d{4})$/);\n  if (dmy) {\n    const [, d, m, y] = dmy;\n    return new Date(Date.UTC(+y, +m - 1, +d));\n  }\n  const iso = new Date(str);\n  return isNaN(iso) ? null : iso;\n}\n\nfunction formatISO(date) {\n  return date ? date.toISOString().split('T')[0] : null;\n}\n\nfunction normalizeKey(key) {\n  return key?.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').replace(/[^a-z0-9]/g, '') || '';\n}\n\nfunction getField(row, ...variants) {\n  const keys = Object.keys(row);\n  for (const v of variants) {\n    const target = normalizeKey(v);\n    for (const k of keys) {\n      if (normalizeKey(k) === target) return row[k];\n    }\n  }\n  return null;\n}\n\nconst items = $input.all();\nconst output = [];\nconst DATA_CORTE = new Date(Date.UTC(2026, 0, 1));\n\nconsole.log(`🚀 Iniciando processamento de ${items.length} linhas...`);\n\nfor (const item of items) {\n  const row = item.json || {};\n  \n  const chapa = String(getField(row, 'MAT', 'MATRICULA', 'CHAPA', 'chapa') || '').trim();\n  const nome = String(getField(row, 'NOME', 'NOME COMPLETO', 'nome') || '').trim();\n  \n  if (!chapa || !nome || nome.toLowerCase().includes('mat')) continue;\n\n  const rawAdmissao = getField(row, 'DATA ADMISSÃO', 'ADMISSAO', 'DATA ADMISSAO', 'DATA ADMISSION');\n  const objDateAdmissao = parseDate(rawAdmissao);\n\n  if (!objDateAdmissao || objDateAdmissao < DATA_CORTE) {\n     // Log de depuração para o usuário ver quem saiu\n     if (chapa === '51624' || nome.includes('ZOE')) {\n       console.log(`⚠️ ZOE ANGEL filtrada! Data: ${rawAdmissao} -> Interpretada: ${objDateAdmissao}`);\n     }\n     continue;\n  }\n\n  const rowData = {\n    chapa,\n    nome,\n    funcao: getField(row, 'FUNÇÃO RM ATUALIZADA', 'FUNCAO', 'CARGO'),\n    area: getField(row, 'AREA DE NEGOCIO', 'AREA'),\n    cid: getField(row, 'CIP DE LIBERAÇÃO', 'CIP'),\n    rh: getField(row, 'RH'),\n    saude: getField(row, 'SAÚDE', 'SAUDE'),\n    seguranca: getField(row, 'SEGURANÇA', 'SEGURANCA'),\n    grd: getField(row, 'GRD'),\n    obs_grd: getField(row, 'OBSERVAÇÃO GRD', 'OBS'),\n    data_admissao: formatISO(objDateAdmissao),\n    liberacao_ecoordin: formatISO(parseDate(getField(row, 'DATA DE LIBERAÇÃO E-COORDINA'))),\n    envio_cliente: formatISO(parseDate(getField(row, 'ENVIO PARA O CLIENTE', 'ENVIO CLIENTE')))\n  };\n\n  output.push({ json: rowData });\n}\n\nconsole.log(`✅ Concluído: ${output.length} registros passaram pelo filtro.`);\nreturn output;"
      },
