      "parameters": {
        "jsCode": "// =====================================================\n// COMPARAÇÃO E SEPARAÇÃO INDIVIDUAL\n// =====================================================\n\n// 1. Pega os 79 itens da transformação\nconst planilhaItems = $('Transformar_Dados1').all();\n\n// 2. Pega os dados do banco (que vieram via input do Supabase)\nconst supabaseItems = $input.all();\n\n// 3. Cria mapa do banco\nconst bancoMap = {};\nfor (const item of supabaseItems) {\n  if (item.json && item.json.chapa) {\n    bancoMap[String(item.json.chapa)] = item.json;\n  }\n}\n\n// 4. Gera um item de output para CADA item da planilha\nreturn planilhaItems.map(pItem => {\n  const row = pItem.json;\n  const chapa = String(row.chapa);\n  const dadoBanco = bancoMap[chapa];\n\n  if (!dadoBanco) {\n    return { json: { ...row, operation: 'insert' } };\n  }\n\n  // Verificação de mudanças para evitar updates desnecessários\n  let hasChanges = false;\n  const ignore = ['id', 'created_at', 'updated_at'];\n  for (const key of Object.keys(row)) {\n    if (ignore.includes(key)) continue;\n    if (String(row[key] || '') !== String(dadoBanco[key] || '')) {\n      hasChanges = true;\n      break;\n    }\n  }\n\n  return { json: { ...row, operation: hasChanges ? 'update' : 'skip' } };\n});"
      },
