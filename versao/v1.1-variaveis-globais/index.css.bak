@import "tailwindcss";

/* Google Fonts Import */
@import url('https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;600;700;800&family=Varela+Round&display=swap');

:root {
  /* Design System Global - Edite aqui para mudar todo o projeto */
  --brand-color: #f02e95;
  --secondary-color: #3B82F6;
  --bg-color: #e2e4e7;
  --radius-main: 48px;
  --radius-card: 32px;

  --text-hero: 56px;
  --text-title: 24px;
  --text-body: 16px;

  --gap-section: 32px;
  --gap-element: 16px;
  --margin-logo-top: 48px;
  --padding-container: 24px;

  --font-sans: 'Nunito Sans', system-ui, -apple-system, sans-serif;
  --font-display: 'Varela Round', sans-serif;
}

@theme {
  /* Premium Soft Palette */
  --color-brand-primary: var(--brand-color);
  --color-brand-secondary: var(--secondary-color);
  --color-brand-accent: var(--brand-color);

  --color-app-bg: var(--bg-color);
  --color-app-card: #FFFFFF;
  --color-app-text: #1E293B;
  --color-app-text-muted: #64748B;
  --color-app-border: #E2E8F0;

  --color-success: #10B981;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;

  --font-sans: var(--font-sans);
  --font-display: var(--font-display);

  /* Geometry & Shadows */
  --radius-xl: var(--radius-card);
  --radius-lg: 24px;
  --radius-md: 16px;

  /* Soft Floating Shadows */
  --shadow-floating: 0 20px 25px -5px rgb(0 0 0 / 0.05), 0 8px 10px -6px rgb(0 0 0 / 0.05);
  --shadow-card: 0 4px 6px -1px rgb(0 0 0 / 0.02), 0 2px 4px -2px rgb(0 0 0 / 0.02);
  --shadow-premium: 0 20px 25px -5px color-mix(in srgb, var(--brand-color) 15%, transparent), 0 10px 10px -5px color-mix(in srgb, var(--brand-color) 5%, transparent);
}

:root {
  font-family: var(--font-sans);
  line-height: 1.5;
  font-weight: 400;
  color-scheme: light;
  background-color: var(--color-app-bg);
  color: var(--color-app-text);
  -webkit-font-smoothing: antialiased;
}

body {
  margin: 0;
  min-height: 100vh;
  background-color: var(--color-app-bg);
}

#root {
  width: 100%;
}

@layer components {
  .btn-primary {
    @apply bg-brand-accent text-white font-bold py-4 px-8 rounded-2xl shadow-xl hover:scale-[1.02] transition-all active:scale-95 text-base flex items-center justify-center gap-2 font-display;
    box-shadow: 0 20px 25px -5px color-mix(in srgb, var(--brand-color) 20%, transparent);
  }

  .card-floating {
    @apply bg-app-card border border-app-border p-6 rounded-[var(--radius-lg)] shadow-card transition-all hover:shadow-floating hover:-translate-y-1;
  }

  .nav-input {
    @apply bg-white border border-app-border rounded-xl py-3 px-5 outline-none focus:border-brand-primary focus:ring-4 focus:ring-brand-primary/10 transition-all text-sm text-app-text font-sans;
  }
}

/* Scrollbar Tweaks */
.scrollbar-hide::-webkit-scrollbar {
  display: none;
}

.scrollbar-hide {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* Typography Helpers */
.font-display {
  font-family: var(--font-display);
}

/* Animations */
@keyframes float {
  0% {
    transform: translateY(0px);
  }

  50% {
    transform: translateY(-10px);
  }

  100% {
    transform: translateY(0px);
  }
}

.animate-float {
  animation: float 4s ease-in-out infinite;
}